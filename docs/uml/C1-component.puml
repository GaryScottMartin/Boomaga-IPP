@startuml
title Boomaga-IPP — System Component Diagram (conforms to code @ 34652fa)
skinparam componentStyle rectangle

' ---- External actors / systems ----
cloud "Host CUPS + applications\n(IPP Everywhere source)" as HOSTCUPS
cloud "Downstream CUPS printer\n(physical or CUPS-PDF)" as TARGET
node "Wayland compositor" as WAYLAND
node "systemd" as SYSTEMD

' ---- Shared library crates ----
package "Shared library crates" {
  [boomaga-core\n(domain types, Error; qpdf)] as CORE
  [boomaga-config\n(Settings, ConfigManager)] as CONFIG
  [boomaga-layout-engine\n(N-up, booklet, transforms)] as LAYOUT
  [boomaga-ipc\n(Unix-socket transport, JSON protocol)] as IPC
}

' ---- Binary: backend daemon ----
package "boomaga-ipp-backend (daemon)" {
  [IppServer\n(IPP 2.x print service, TCP)] as IPPSRV
  [JobProcessor\n(worker pool)] as PROC
  [JobQueue\n(tokio mpsc)] as QUEUE
}

' ---- Binary: GUI ----
package "boomaga-preview (GUI · Xilem)" {
  [AppData\n(Xilem app state)] as APP
  [DocumentRenderer\n(poppler)] as RENDER
}

' ==== Realized in code (solid) ====
HOSTCUPS --> IPPSRV        : IPP Everywhere (driverless);\nCUPS forwards jobs IN
IPPSRV --> PROC
PROC --> QUEUE
IPPSRV ..> CORE
PROC   ..> CORE
QUEUE  ..> CORE
APP    ..> CORE
APP    ..> CONFIG
CONFIG ..> CORE
LAYOUT ..> CORE
IPC    ..> CORE
APP --> RENDER
WAYLAND --> APP            : display / input
SYSTEMD ..> IPPSRV         : socket activation /\nlifecycle (zbus_systemd)

' ==== Decided design, NOT yet wired in code (dashed = Phase 1 gap) ====
IPPSRV .[#gray,dashed].> IPC    : <<planned>> notify GUI (Unix socket + JSON)
APP    .[#gray,dashed].> IPC    : <<planned>> receive job / status
PROC   .[#gray,dashed].> LAYOUT : <<planned>> imposition
APP    .[#gray,dashed].> LAYOUT : <<planned>> imposition preview
APP    .[#gray,dashed].> TARGET : <<planned>> submit downstream\n(CUPS API; no cups dep yet)

legend right
  Solid  = present in code / Cargo deps @ 34652fa
  Dashed = decided design, not yet wired (Phase 1)
endlegend
@enduml
