@startuml
title Boomaga-IPP — System Class Diagram (conforms to code @ 34652fa)
skinparam classAttributeIconSize 0
hide empty members

package "boomaga-core" {
  class Document {
    +id: String
    +file_path: PathBuf
    +file_type: FileType
    +title: String
    +author: Option<String>
    +keywords: Vec<String>
    +pages: Vec<Page>
    +page_count(): usize
    +add_page(Page)
    +parse_metadata()
  }
  class Page {
    +number: usize
    +width: f64
    +height: f64
    +orientation: Orientation
    +contents: PageContents
    +has_content(): bool
  }
  enum PageContents {
    Vector
    Raster
    Pdf
  }

  class PrintJobRequest {
    +job_id: JobId
    +file_path: PathBuf
    +file_type: FileType
    +printer_name: Option<String>
    +options: PrintOptions
  }
